{
  "extends": [
    "@commitlint/config-conventional"
  ],
  "parserPreset": {
    "parserOpts": {
      "headerPattern": "^(?<type>.+):\\s(?<subject>.+)\\s\\(#\\d+\\)$",
      "headerCorrespondence": [
        "type",
        "subject"
      ]
    }
  },
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "add",
        "fix",
        "update"
      ]
    ]
  }
}
